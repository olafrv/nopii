{
  "name": "nopii-proxy",
  "type": "module",
  "version": "1.0.0",
  "description": "PII-redaction proxy for the Anthropic API in Claude Code (CLI)",
  "main": "src/server.js",
  "packageManager": "pnpm@11.5.2",
  "scripts": {
    "dev": "node --env-file=.env --watch src/server.js",
    "start": "node --env-file=.env src/server.js",
    "oauth-login": "node --env-file-if-exists=.env src/oauth-login.js",
    "model:download": "node --env-file-if-exists=.env scripts/download-model.mjs",
    "dataset:download": "node --env-file-if-exists=.env scripts/download-dataset.mjs",
    "sync:node-pin": "node scripts/sync-node-pin.mjs",
    "check:deny-rules": "node scripts/check-deny-rules.mjs",
    "leak-stats": "node --env-file-if-exists=.env test/leak-stats.mjs",
    "test": "node --test test/leak-check.js"
  },
  "engines": {
    "node": "24.16.0"
  },
  "license": "MIT",
  "dependencies": {
    "@xenova/transformers": "2.17.2",
    "express": "4.22.2",
    "gliner": "0.0.19"
  }
}
