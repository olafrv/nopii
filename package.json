{
  "name": "nopii-proxy",
  "type": "module",
  "version": "1.0.0",
  "description": "Local/remote PII-redaction reverse proxy for the Anthropic Messages API (Claude Code via ANTHROPIC_BASE_URL)",
  "main": "src/server.js",
  "packageManager": "pnpm@11.5.2",
  "scripts": {
    "dev": "node --env-file=.env --watch src/server.js",
    "start": "node --env-file=.env src/server.js",
    "check:node-pin": "sh ./pnpm-node-pin-check.sh",
    "preinstall": "pnpm run check:node-pin",
    "pretest": "pnpm run check:node-pin",
    "test": "node --test test/leak-check.js"
  },
  "engines": {
    "node": "24.16.0"
  },
  "license": "MIT",
  "dependencies": {
    "@xenova/transformers": "2.17.2",
    "express": "4.22.2",
    "gliner": "0.0.19"
  }
}
