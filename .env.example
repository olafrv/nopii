# Port the proxy listens on
PORT=8788

# Upstream Anthropic API (change only if you use a gateway/region endpoint)
ANTHROPIC_UPSTREAM_URL=https://api.anthropic.com

# Fail behavior when PII detection throws:
#   (default) FAIL_CLOSED — block the request so PII can never leak
#   FAIL_OPEN=true — forward the ORIGINAL prompt (PII NOT redacted). Use with care.
FAIL_OPEN=false

# Auth mode:
#   (default) passthrough — forward Claude Code's auth header untouched (API-key auth)
#   oauth — use your Claude Pro/Max SUBSCRIPTION. Run `pnpm run oauth-login` once, then
#           nopii injects its own OAuth token. Point Claude Code at the proxy with a
#           placeholder ANTHROPIC_API_KEY (any sk-ant-... value) so it still sends requests.
# AUTH_MODE=passthrough

# Where the OAuth tokens are stored (oauth mode). Plaintext JSON, mode 0600.
# NOPII_CREDENTIALS_DIR=~/.nopii

# Detection tuning (optional — defaults shown)

# Path to the ONNX weights (<repo>/onnx/<variant> layout, resolved from cwd).
# Point elsewhere to swap model variants.
# GLINER_MODEL_PATH=model/gliner_medium-v2.1/onnx/model_fp16.onnx

# Hugging Face repo id for the tokenizer files (auto-fetched on first run).
# GLINER_TOKENIZER=onnx-community/gliner_medium-v2.1

# Where the auto-fetched tokenizer is cached (kept under model/ so it survives
# a node_modules reinstall). Created on first run.
# GLINER_CACHE_DIR=model/.cache

# Detection threshold, 0..1 — lower = more aggressive (more spans flagged). Below ~0.4
# GLiNER starts flagging pronouns/common words as PERSON; a stopword guard (src/ner.js)
# also drops those regardless of score.
# GLINER_THRESHOLD=0.5

# Comma-separated entity labels to detect.
# GLINER_ENTITIES=person,email,phone,address,city,state,country,zipcode,ip_address,national_id,user_id,credit_card,account,token

# Also redact PII inside tool_result content fed back by the user (default true)
# REDACT_TOOL_RESULTS=true

# Verbose logging in dev: logs span counts + a masked token->value map (first/last char
# of each value only; never full values). Don't enable in prod.
# NODE_ENV=development
# DEBUG=true

# DEBUG_UNMASK=true logs the FULL original PII values in that map (requires DEBUG=true).
# Deliberate opt-in for debugging detection — leaks PII to logs. NEVER in prod.
# DEBUG_UNMASK=true
